{
  "name": "screenshot-service",
  "private": true,
  "description": "Self-hosted screenshot upload service with public asset links and OIDC admin controls.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=config/dev.env --filter @screenshot/server dev",
    "dev:web": "bun --filter @screenshot/web dev",
    "build": "bun --filter @screenshot/web build && bun --filter @screenshot/server build",
    "start": "bun --filter @screenshot/server start",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
